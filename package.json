{
    "name":  "electron-jam",
    "version":  "1.0.0",
    "description":  "YouTube Music with Jam - listen together in real-time",
    "main":  "main.js",
    "scripts":  {
                    "start":  "electron .",
                    "build":  "electron-builder --win --x64 --config.win.signAndEditExecutable=false"
                },
    "build":  {
                  "appId":  "com.ytmjam.app",
                  "productName":  "YouTube Music Jam",
                  "win":  {
                              "target":  "portable",
                              "icon":  "build/78a85b49-a99d-4c3e-8b8d-d8fcfdeb5559.ico"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true
                           },
                  "files":  [
                                "main.js",
                                "preload.js",
                                "jam-inject.js",
                                "package.json"
                            ]
              },
    "devDependencies":  {
                            "electron":  "^41.2.0",
                            "electron-builder":  "^24.13.3"
                        }
}
